package tests:component@0.1.0;

interface types {
    record entity {
        id: s32,
        name: string,
        position: point
    }

    record point {
        x: s32,
        y: s32
    }

    enum status {
        active,
        inactive,
        pending
    }

    flags permission {
        read,
        write,
        execute
    }
}

world type-tests {
    use types.{point, status, permission};

    export add-u8: func(x: u8, y: u8) -> u8;
    export add-s8: func(x: s8, y: s8) -> s8;
    export add-u16: func(x: u16, y: u16) -> u16;
    export add-s16: func(x: s16, y: s16) -> s16;
    export add-u32: func(x: u32, y: u32) -> u32;
    export add-s32: func(x: s32, y: s32) -> s32;
    export add-u64: func(x: u64, y: u64) -> u64;
    export add-s64: func(x: s64, y: s64) -> s64;
    export add-f32: func(x: f32, y: f32) -> f32;
    export add-f64: func(x: f64, y: f64) -> f64;
    export add-point: func(p1: point, p2: point) -> point;
    export uppercase: func(s: string) -> string;
    export multiply-list: func(%list: list<u32>, factor: u32) -> list<u32>;
    export return-status: func(status: status) -> status;
    export return-status-list: func(statuses: list<status>) -> list<status>;
    export return-permission: func(permission: permission) -> permission;
    export return-permission-list: func(permissions: list<permission>) -> list<permission>;
}

world test {
    use types.{entity};

    include type-tests;

    export register-entity: func(e: entity);
    export register-entities: func(e: list<entity>);
    export get-entity: func(id: s32) -> entity;
    export get-entities: func() -> list<entity>;

    export set-flag: func(flag: bool);
    export get-flag: func() -> bool;
    export get-host-entity-description: func() -> string;

    export sum-nested-list: func(nested: list<list<u32>>) -> u32;

    export host-callback: func();
    export host-combine-string: func(s1: string, s2: string) -> string;
    export combine-string: func(s1: string, s2: string) -> string;

    export accept-string: func(s: string);
    export return-string: func(length: u32) -> string;

    import callback: func();
    import callback-combine-string: func(s1: string, s2: string) -> string;
    import get-host-entity: func() -> entity;
}